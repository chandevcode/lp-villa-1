---
const { title, location, price, rating, category, image, icon } = Astro.props;
---

<div class="text-left group cursor-pointer">
  <div class="relative h-80 rounded-2xl overflow-hidden mb-4">
    <img 
      src={image} 
      class="w-full h-full object-cover transition duration-500 group-hover:scale-110" 
      alt={title} 
    />
    <span class="absolute top-4 left-4 bg-white/20 backdrop-blur-md text-white text-[10px] px-3 py-1 rounded-full uppercase tracking-widest">
      <i class={`fa-solid ${icon} mr-1`}></i> {category}
    </span>
    <span class="absolute bottom-4 left-4 bg-white/80 text-black text-[10px] px-2 py-1 rounded-md font-bold">
      ★ {rating}
    </span>
  </div>
  <h3 class="text-xl mb-1 italic">{title}</h3>
  <p class="text-xs text-gray-400 mb-4">{location}</p>
  <div class="flex items-center justify-between">
    <span class="text-sm font-light">
      From <span class="font-bold">${price}</span> / night
    </span>
    <button class="text-[10px] uppercase tracking-widest border border-gray-200 px-4 py-2 rounded-md hover:bg-black hover:text-white transition">
      View Villa →
    </button>
  </div>
</div>
